{
  "name": "myparcelnl/magento",
  "version": "5.5.2",
  "description": "A Magento 2 module that creates MyParcel labels",
  "keywords": [
    "myparcel",
    "postnl",
    "magento2"
  ],
  "homepage": "https://www.myparcel.nl",
  "license": "MIT",
  "authors": [
    {
      "name": "Joeri van Veen",
      "email": "support@myparcel.nl"
    },
    {
      "name": "Richard Perdaan",
      "email": "support@myparcel.nl"
    }
  ],
  "type": "magento2-module",
  "repositories": [
    {
      "type": "composer",
      "url": "https://mirror.mage-os.org/"
    }
  ],
  "require": {
    "php": "^7.4 || ^8.0",
    "myparcelnl/sdk": "^v11@beta",
    "magento/framework": ">=101.0.8 <102 || >=102.0.1"
  },
  "require-dev": {
    "justinrainbow/json-schema": "^6.0",
    "pestphp/pest": "^2.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "files": [
      "registration.php"
    ],
    "psr-4": {
      "MyParcelNL\\Magento\\": "src/",
      "MyParcelNL\\Magento\\Controller\\": "Controller/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "MyParcelNL\\Magento\\Tests\\": "Tests/"
    }
  },
  "scripts": {
    "pre-package-uninstall": "MyParcelNL\\Magento\\Setup\\Uninstall::uninstall"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "magento/composer-dependency-version-audit-plugin": true
    }
  }
}
